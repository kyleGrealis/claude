{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/kyle/dev/claude-memory-compiler && uv run python hooks/session-start.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/kyle/dev/claude-memory-compiler && uv run python hooks/pre-compact.py",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/kyle/dev/claude-memory-compiler && uv run python hooks/session-end.py",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "cloudflare-workers@tenequm-plugins": true
  },
  "effortLevel": "high",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(find*)",
      "Bash(node*)",
      "Bash(pnpm*)",
      "Bash(tsx*)",
      "Bash(uv*)",
      "Bash(Rscript*)",
      "Bash(ssh*)",
      "Bash(curl*)",
      "Bash(which*)",
      "Bash(echo*)",
      "Bash(pwd*)",
      "Bash(systemctl status*)",
      "Bash(systemctl list-unit-files*)",
      "Bash(trash-put*)",
      "Bash(trash-list*)",
      "Bash(trash-restore*)"
    ],
    "deny": [
      "Bash(sudo*)",
      "Bash(rm*)"
    ],
    "ask": [
      "Bash(trash-empty*)"
    ]
  }
}